# 即声 SpeakNow - 火山引擎 ASR 凭证配置
# 请复制此文件为 .env 并填入你的凭证
# 获取地址：https://console.volcengine.com/speech/service/overview

# 应用 APP ID（必填，用于 WebSocket 流式识别）
VOLC_APP_KEY=your_app_id_here

# Access Token（必填，用于 WebSocket 流式识别）
VOLC_ACCESS_KEY=your_access_token_here

# API Key（选填，仅 HTTP 备用模式需要）
VOLC_API_KEY=your_api_key_here
